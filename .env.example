# === Zalo Sales CRM ===
PORT=3000
NODE_ENV=production
APP_URL=https://zalo.ngay.top

# Security — generate strong random values for production
JWT_SECRET=
ENCRYPTION_KEY=

# Database
DB_USER=crmuser
DB_PASSWORD=
DB_NAME=zalocrm
DATABASE_URL=postgresql://crmuser:password@db:5432/zalocrm

# Storage
UPLOAD_DIR=/var/lib/zalo-crm/files

# AI - OpenAI
OPENAI_API_KEY=sk-xxxxxxxx
OPENAI_MODEL=gpt-4o-mini
